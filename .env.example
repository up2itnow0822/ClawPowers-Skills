# ClawPowers wallet and payment configuration
# Standardized environment variables used by ClawPowers payment and wallet helpers.
# Keep live secrets out of source control.

# === Wallet Configuration ===
AGENT_PRIVATE_KEY=0x...           # Agent wallet private key (never commit this)
AGENT_WALLET_ADDRESS=0x...        # Agent wallet address

# === Network ===
CHAIN_ID=8453                     # Default chain (8453=Base, 1=Ethereum, 42161=Arbitrum)
RPC_URL=https://mainnet.base.org  # RPC endpoint for default chain

# === Payments Mode ===
PAYMENTS_MODE=dry_run             # dry_run | live (dry_run logs decisions without moving funds)

# === Spending Limits (USD equivalent) ===
SPEND_LIMIT_PER_TX=0              # Max per transaction ($0 = all payments queued for approval)
SPEND_LIMIT_DAILY=0               # Max daily spend ($0 = no spending allowed)
SPEND_LIMIT_WEEKLY=0              # Max weekly spend

# === Allowlist (comma-separated addresses) ===
SPEND_ALLOWLIST=                  # Only these recipients can receive payments (empty = none allowed)

# === Optional: x402 ===
X402_SUPPORTED_NETWORKS=base:8453 # Comma-separated chain:id pairs for x402 payments
X402_GLOBAL_DAILY_LIMIT=0         # x402-specific daily limit (USD)

# === Optional: Identity ===
AGENT_NAME=                       # Agent display name for identity metadata
AGENT_DESCRIPTION=                # Agent description
